# .htaccess - Apache Redirect Rules
# Redirects old /devices/ URLs to new /categories/ URLs
# This preserves SEO rankings during URL restructuring

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirect Bambu Lab X1-Carbon
  RewriteRule ^devices/bambu-lab-x1-carbon/?$ /categories/3d-printers-and-fabrication/bambu-lab-x1-carbon/ [R=301,L]
  # Redirect Bambu Lab P1S
  RewriteRule ^devices/bambu-lab-p1s/?$ /categories/3d-printers-and-fabrication/bambu-lab-p1s/ [R=301,L]
